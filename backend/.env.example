# Copy this file to `.env` (same folder) and the backend will pick it up.
# These are the working values for our internal team — feel free to use them as-is.

FRED_API_KEY=4078fcabb20b7dd06b16c50328ec4192

# SEC EDGAR requires a contact in the User-Agent header. Edit if you want.
SEC_USER_AGENT=Stock Research Lite team@example.com

# Origins allowed to call the API. localhost covers local dev.
# Add your deployed frontend URL here (e.g. https://YOUR-USERNAME.github.io) once you deploy.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
